{
  "expo": {
    "name": "Kizz",
    "slug": "kizz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/kizz-logo-v2.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.kizz.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0E0D",
        "foregroundImage": "./assets/kizz-logo-v2.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "androidNavigationBar": {
      "backgroundColor": "#0A0E0D",
      "barStyle": "light-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-status-bar",
      "expo-sharing",
      "@maplibre/maplibre-react-native"
    ]
  }
}
